{
  "name": "web-shop-backend",
  "version": "1.0.0",
  "description": "SSR frontend and API gateway for Aether Motors",
  "main": "server.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/app.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/app.css --watch",
    "start": "npm run build:css && node server.js",
    "dev": "npm run build:css && concurrently -n css,server -c cyan,green \"npm:watch:css\" \"node --watch server.js\""
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cookie-parser": "^1.4.6",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.0"
  }
}
