<header class="fixed top-0 w-full z-50 bg-[#121314]/80 backdrop-blur-xl shadow-lg">
  <div class="max-w-page mx-auto px-8 py-4 flex items-center justify-between">
    <a
      href="/"
      class="text-2xl font-black tracking-tighter text-primary font-headline uppercase"
    >
      Aether Motors
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <% const navLinks = [
        { href: '/configurator', label: 'Configurator', key: 'configurator' },
        { href: '/merchandise', label: 'Merchandise', key: 'merchandise' },
        { href: '/gallery', label: 'Gallery', key: 'gallery' },
        { href: '/roadmap', label: 'Roadmap', key: 'roadmap' }
      ]; %>
      <% navLinks.forEach(function(link) { %>
        <% const isActive = active === link.key; %>
        <a
          href="<%= link.href %>"
          class="font-headline font-bold tracking-tight uppercase text-sm transition-colors <%= isActive ? 'text-primary border-b-2 border-primary pb-1' : 'text-secondary hover:text-white' %>"
        >
          <%= link.label %>
        </a>
      <% }); %>
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        data-cart-toggle
        class="relative w-10 h-10 flex items-center justify-center text-white hover:text-primary transition-colors"
        aria-label="Open cart"
      >
        <span class="material-symbols-outlined">shopping_cart</span>
        <% if (cartCount > 0) { %>
          <span class="absolute -top-1 -right-1 bg-primary text-on-primary-container text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center">
            <%= cartCount %>
          </span>
        <% } %>
      </button>
      <button
        type="button"
        class="w-10 h-10 flex items-center justify-center text-white hover:text-primary transition-colors"
        aria-label="Account"
      >
        <span class="material-symbols-outlined">account_circle</span>
      </button>

      <button
        type="button"
        data-mobile-menu-toggle
        class="md:hidden w-10 h-10 flex items-center justify-center text-white hover:text-primary transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="material-symbols-outlined" data-menu-icon>menu</span>
      </button>
    </div>
  </div>

  <nav
    data-mobile-menu
    hidden
    class="md:hidden border-t border-white/5 bg-[#121314]/95 backdrop-blur-xl px-8 py-4 flex flex-col gap-4"
  >
    <% navLinks.forEach(function(link) { %>
      <% const isActive = active === link.key; %>
      <a
        href="<%= link.href %>"
        class="font-headline font-bold tracking-tight uppercase text-sm transition-colors <%= isActive ? 'text-primary border-b-2 border-primary pb-1' : 'text-secondary hover:text-white' %>"
      >
        <%= link.label %>
      </a>
    <% }); %>
  </nav>
</header>

<%# Spacer to offset fixed header %>
<div class="h-[72px]" aria-hidden="true"></div>
