<main class="bg-surface min-h-screen">
  <%# ── Micro-frontend host page ─────────────────────────────────────────
       The configurator UI is rendered by services/configurator-service
       (Node.js, port 3008). We embed it here via an <iframe> pointed at
       /configurator-ui — a path the SSR backend proxies to the
       configurator service (see ADR13 and the http-proxy-middleware
       block in server.js).

       The iframe loads the FULL configurator HTML (Tailwind, body shot,
       color/wheel/interior selectors, AI panel, checkout button) from
       the service. The only JavaScript the host page itself runs is
       configurator-host.js, which listens for a postMessage from the
       iframe when the user clicks "Continue to Checkout" and hands off
       to the classic POST /configurator/order flow. %>

  <section class="px-0 py-0 max-w-page mx-auto">
    <iframe
      id="configurator-frame"
      src="<%= iframeSrc %>"
      title="Aether Motors Configurator"
      class="w-full block border-0"
      style="height: calc(100vh - 72px); min-height: 720px; background: #121314;"
      allow="autoplay">
    </iframe>
  </section>

  <%# Hidden form used by configurator-host.js to bridge the iframe's
     postMessage hand-off into the existing POST /configurator/order
     flow. The form posts to the same Express route the configurator
     UI used to submit directly. %>
  <form id="configurator-checkout-form" method="POST" action="/configurator/order" class="hidden">
    <input type="hidden" name="vehicleId" />
    <input type="hidden" name="colorId" />
    <input type="hidden" name="wheelsId" />
    <input type="hidden" name="interiorId" />
  </form>
</main>
