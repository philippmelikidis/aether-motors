<main>
  <%# ── Hero Section ── %>
  <section class="relative h-screen w-full overflow-hidden -mt-[72px]">
    <img
      src="<%= vehicle.image %>"
      alt="<%= vehicle.name %>"
      class="absolute inset-0 w-full h-full object-cover opacity-70"
    />

    <div class="absolute inset-0 bg-gradient-to-t from-surface-dim via-surface-dim/40 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-surface-dim/60 via-transparent to-transparent"></div>

    <div class="relative z-10 flex h-full flex-col justify-end px-8 pb-32 max-w-page mx-auto">
      <p class="font-label text-primary text-xs tracking-[0.3em] uppercase font-bold mb-4">
        The Future of Automotive Performance
      </p>
      <h1 class="font-headline text-7xl md:text-9xl font-black tracking-tighter text-white leading-[0.9] mb-6">
        AETHER<br/>
        <span class="text-primary text-glow">MOTORS</span>
      </h1>
      <p class="font-body text-secondary text-lg max-w-xl mb-10">
        Cloud-native engineering meets uncompromising design. Experience the
        pinnacle of electric performance — engineered for those who demand the
        extraordinary.
      </p>

      <div class="flex gap-4">
        <a href="/configurator" class="btn-primary px-10 py-4 primary-glow inline-flex items-center gap-2">
          <span>Build Yours</span>
          <span class="material-symbols-outlined text-lg">arrow_forward</span>
        </a>
        <a href="/gallery" class="btn-secondary inline-flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">play_arrow</span>
          <span>Watch Film</span>
        </a>
      </div>
    </div>

    <div class="absolute bottom-12 right-12 z-10 hidden lg:flex gap-12 items-end">
      <% vehicle.specs.forEach(function(spec) { %>
        <div>
          <span class="block text-[10px] font-label uppercase tracking-widest text-secondary/40 mb-1">
            <%= spec.label %>
          </span>
          <span class="text-4xl font-headline font-bold text-white tracking-tighter">
            <%= spec.value %><span class="text-primary text-xl"><%= spec.unit %></span>
          </span>
        </div>
      <% }); %>
    </div>
  </section>

  <%# ── Navigation Cards Section ── %>
  <section class="px-8 py-24 max-w-page mx-auto">
    <div class="text-center mb-16">
      <p class="font-label text-primary text-xs tracking-[0.2em] uppercase font-bold mb-3">
        Explore
      </p>
      <h2 class="font-headline text-5xl font-bold tracking-tighter text-white">
        THE ECOSYSTEM
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <% navCards.forEach(function(card) { %>
        <a href="<%= card.href %>" class="group">
          <div class="glass-panel rounded-xl p-8 h-full transition-all duration-300 hover:shadow-[0_20px_50px_rgba(0,218,248,0.1)] hover:border-primary/20">
            <div class="w-14 h-14 rounded-lg bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary/20 transition-colors">
              <span class="material-symbols-outlined text-primary text-2xl"><%= card.icon %></span>
            </div>
            <h3 class="font-headline font-bold text-xl text-white uppercase tracking-tight mb-3"><%= card.title %></h3>
            <p class="text-secondary text-sm font-body"><%= card.description %></p>
            <div class="mt-6 flex items-center gap-2 text-primary font-label text-xs font-bold uppercase tracking-widest group-hover:translate-x-2 transition-transform">
              <span>Explore</span>
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
  </section>

  <%# ── Featured Vehicle Showcase ── %>
  <section class="px-8 pb-24 max-w-page mx-auto">
    <div class="relative h-96 rounded-xl overflow-hidden group">
      <img
        src="<%= vehicle.image %>"
        alt="<%= vehicle.name %>"
        class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-[2000ms]"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-surface-dim via-surface-dim/60 to-transparent"></div>
      <div class="relative z-10 flex items-center h-full px-12">
        <div>
          <p class="font-label text-primary text-xs tracking-[0.2em] uppercase font-bold mb-2">
            Now Configurable
          </p>
          <h2 class="font-headline text-5xl font-black text-white tracking-tighter uppercase mb-2">
            <%= vehicle.name %>
          </h2>
          <p class="text-secondary font-body mb-1"><%= vehicle.subtitle %></p>
          <p class="text-2xl font-headline font-bold text-white mt-4">
            Starting at <span class="text-primary"><%= formatPrice(vehicle.basePrice) %></span>
          </p>
          <a href="/configurator" class="btn-primary inline-block px-8 py-3 mt-6 primary-glow">
            Configure Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <%# ── CTA Banner ── %>
  <section class="border-t border-white/5 py-20 text-center">
    <div class="w-px h-12 bg-primary mx-auto mb-8"></div>
    <h2 class="font-headline text-4xl font-bold text-white tracking-tighter mb-4">
      ENGINEERED FOR THE CLOUD.
    </h2>
    <p class="text-secondary max-w-lg mx-auto mb-8 text-sm uppercase tracking-wider">
      Join the select few who experience the pinnacle of cloud-native automotive engineering.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/configurator" class="bg-white text-surface px-8 py-3 font-headline font-black uppercase tracking-widest text-[10px] rounded-md hover:bg-primary transition-colors">
        Build Yours
      </a>
      <a href="/gallery" class="text-white border border-white/20 px-8 py-3 font-headline font-black uppercase tracking-widest text-[10px] rounded-md hover:border-primary transition-colors">
        Request Catalog
      </a>
    </div>
  </section>
</main>
