<main class="pt-16 pb-24 px-8 max-w-6xl mx-auto">
  <div class="mb-10 text-center">
    <p class="font-label text-primary text-xs tracking-[0.3em] uppercase font-bold mb-3">Step 2 of 3 — Checkout</p>
    <h1 class="font-headline text-5xl font-black tracking-tighter text-white">
      ALMOST YOURS.
    </h1>
    <p class="font-body text-on-surface/60 mt-3">
      Enter your delivery details below to finalize the reservation.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <%# ── Form column (2/3) ── %>
    <form method="POST" action="<%= submitUrl %>" class="lg:col-span-2 glass-panel rounded-2xl p-8 space-y-8">
      <% Object.keys(hidden || {}).forEach(function(key) { %>
        <input type="hidden" name="<%= key %>" value="<%= hidden[key] %>" />
      <% }); %>

      <section>
        <h2 class="font-headline font-bold text-sm uppercase tracking-widest text-on-surface mb-5 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-lg">person</span>
          Contact
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-on-surface/60">Full name</span>
            <input type="text" name="fullName" required autocomplete="name"
                   class="mt-2 w-full rounded-lg bg-surface border border-white/10 px-4 py-3 text-sm text-on-surface focus:outline-none focus:border-primary/50" />
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-widest text-on-surface/60">Email</span>
            <input type="email" name="email" required autocomplete="email"
                   class="mt-2 w-full rounded-lg bg-surface border border-white/10 px-4 py-3 text-sm text-on-surface focus:outline-none focus:border-primary/50" />
          </label>
          <label class="block md:col-span-2">
            <span class="text-[10px] uppercase tracking-widest text-on-surface/60">Phone <span class="opacity-50">(optional)</span></span>
            <input type="tel" name="phone" autocomplete="tel"
                   class="mt-2 w-full rounded-lg bg-surface border border-white/10 px-4 py-3 text-sm text-on-surface focus:outline-none focus:border-primary/50" />
          </label>
        </div>
      </section>

      <section>
        <h2 class="font-headline font-bold text-sm uppercase tracking-widest text-on-surface mb-5 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-lg">local_shipping</span>
          Delivery address
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-6 gap-5">
          <label class="block md:col-span-6">
            <span class="text-[10px] uppercase tracking-widest text-on-surface/60">Street &amp; number</span>
            <input type="text" name="street" required autocomplete="street-address"
                   class="mt-2 w-full rounded-lg bg-surface border border-white/10 px-4 py-3 text-sm text-on-surface focus:outline-none focus:border-primary/50" />
          </label>
          <label class="block md:col-span-2">
            <span class="text-[10px] uppercase tracking-widest text-on-surface/60">ZIP / Postcode</span>
            <input type="text" name="zip" required autocomplete="postal-code"
                   class="mt-2 w-full rounded-lg bg-surface border border-white/10 px-4 py-3 text-sm text-on-surface focus:outline-none focus:border-primary/50" />
          </label>
          <label class="block md:col-span-4">
            <span class="text-[10px] uppercase tracking-widest text-on-surface/60">City</span>
            <input type="text" name="city" required autocomplete="address-level2"
                   class="mt-2 w-full rounded-lg bg-surface border border-white/10 px-4 py-3 text-sm text-on-surface focus:outline-none focus:border-primary/50" />
          </label>
          <label class="block md:col-span-6">
            <span class="text-[10px] uppercase tracking-widest text-on-surface/60">Country</span>
            <input type="text" name="country" required autocomplete="country-name" value="Germany"
                   class="mt-2 w-full rounded-lg bg-surface border border-white/10 px-4 py-3 text-sm text-on-surface focus:outline-none focus:border-primary/50" />
          </label>
        </div>
      </section>

      <div class="flex flex-wrap items-center gap-4 pt-4">
        <button type="submit" class="btn-primary primary-glow px-8 py-4 text-sm font-bold uppercase tracking-widest flex items-center gap-2">
          Place reservation
          <span class="material-symbols-outlined text-lg">arrow_forward</span>
        </button>
        <a href="<%= backUrl %>" class="text-xs uppercase tracking-widest text-on-surface/60 hover:text-on-surface transition-colors">
          ← Back
        </a>
        <p class="text-[10px] text-on-surface/40 w-full mt-2">
          By placing the reservation you agree to the deposit terms. No payment is taken at this step.
        </p>
      </div>
    </form>

    <%# ── Order summary (1/3) ── %>
    <aside class="glass-panel rounded-2xl p-6 h-fit lg:sticky lg:top-24">
      <% if (summary.image) { %>
        <div class="rounded-xl overflow-hidden mb-5 aspect-[16/10] bg-surface-container-highest">
          <img src="<%= summary.image %>" alt="<%= summary.heading %>" class="w-full h-full object-cover"
               onerror="this.onerror=null;this.src='/images/vehicles/placeholder.svg';" />
        </div>
      <% } %>
      <p class="text-[10px] uppercase tracking-widest text-on-surface/60"><%= summary.subheading %></p>
      <h3 class="font-headline font-black text-xl text-on-surface mb-5"><%= summary.heading %></h3>

      <div class="space-y-3 text-sm">
        <% summary.lineItems.forEach(function(item) { %>
          <div class="flex justify-between gap-4">
            <span class="text-on-surface/70 truncate"><%= item.label %></span>
            <span class="text-on-surface font-bold shrink-0"><%= item.value %></span>
          </div>
        <% }); %>
      </div>

      <div class="h-px bg-white/10 my-5"></div>
      <div class="flex justify-between items-center">
        <span class="text-on-surface/60 uppercase tracking-wider text-xs">Total</span>
        <span class="text-2xl font-headline font-black text-primary"><%= summary.totalFormatted %></span>
      </div>
    </aside>
  </div>
</main>
