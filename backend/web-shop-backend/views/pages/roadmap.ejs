<div class="relative h-screen overflow-hidden -mt-[72px] pt-[72px]">
  <%# ── Sidebar ── %>
  <aside class="fixed left-0 top-0 h-full w-64 bg-surface border-r border-white/5 z-30 pt-24 pb-8">
    <div class="px-6 mb-10">
      <h2 class="text-primary font-headline font-black text-lg uppercase tracking-widest">
        Project Zenith
      </h2>
      <p class="text-[10px] text-on-surface/50 uppercase tracking-widest mt-1">
        V12 Hybrid Concept
      </p>
    </div>

    <nav class="flex flex-col gap-1 px-3">
      <% const navItems = [
        { label: 'Models', icon: 'directions_car', active: false },
        { label: 'Performance', icon: 'speed', active: false },
        { label: 'Interior', icon: 'chair', active: false },
        { label: 'Summary', icon: 'summarize', active: true },
      ]; %>
      <% navItems.forEach(function(item) { %>
        <button class="flex items-center gap-3 px-4 py-3 rounded-lg text-left transition-colors <%= item.active ? 'text-primary bg-primary/10' : 'text-on-surface/60 hover:text-white hover:bg-white/5' %>">
          <span class="material-symbols-outlined text-xl"><%= item.icon %></span>
          <span class="text-xs font-headline font-bold uppercase tracking-widest"><%= item.label %></span>
        </button>
      <% }); %>
    </nav>

    <div class="absolute bottom-8 left-0 w-full px-4">
      <button class="w-full primary-gradient-glow text-on-primary-container font-headline font-black uppercase tracking-widest text-xs rounded-lg py-3 transition-all hover:brightness-110 active:scale-95">
        Save Configuration
      </button>
    </div>
  </aside>

  <%# ── Main map area ── %>
  <main class="pl-64 relative overflow-hidden h-full">
    <%# Layer 1: dot grid background %>
    <div class="absolute inset-0 map-grid bg-surface"></div>

    <%# Layer 2: SVG path + markers %>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="relative w-[80%] h-[60%]">
        <svg viewBox="0 0 800 500" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M100,400 Q250,380 300,250 T600,100" stroke="#00daf8" stroke-opacity="0.5" stroke-width="3" stroke-dasharray="12 6" filter="url(#glow)" />
          <path d="M100,400 Q250,380 300,250 T600,100" stroke="#00daf8" stroke-opacity="0.3" stroke-width="2" stroke-dasharray="12 6" />
          <defs>
            <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
              <feGaussianBlur stdDeviation="8" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
          </defs>
        </svg>

        <%# Start marker %>
        <div class="absolute bottom-[20%] left-[12%] -translate-x-1/2 translate-y-1/2">
          <div class="w-3 h-3 rounded-full bg-white shadow-[0_0_12px_rgba(255,255,255,0.6)]"></div>
        </div>

        <%# Destination marker %>
        <% const destination = waypoints.find(function(w) { return w.type === 'destination'; }); %>
        <div class="absolute top-[16%] right-[22%] -translate-x-1/2 -translate-y-1/2 flex flex-col items-center gap-2">
          <div class="relative flex items-center justify-center">
            <div class="absolute w-8 h-8 rounded-full border border-primary/30 animate-ping"></div>
            <div class="absolute w-5 h-5 rounded-full border border-primary/50"></div>
            <div class="w-3 h-3 rounded-full bg-primary shadow-[0_0_12px_#00daf8]"></div>
          </div>
          <% if (destination) { %>
            <div class="glass-card rounded-lg px-3 py-1.5 mt-2">
              <p class="text-[10px] font-headline font-bold uppercase tracking-widest whitespace-nowrap">
                <%= destination.name %>
              </p>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <%# Layer 3: satellite overlay %>
    <div class="absolute inset-0 mix-blend-overlay opacity-20 grayscale">
      <img src="<%= mapImage %>" alt="Satellite map overlay" class="w-full h-full object-cover" />
    </div>

    <%# Floating UI overlays %>
    <div class="relative z-10 p-12 h-full flex flex-col justify-between pointer-events-none">
      <%# TOP row %>
      <div class="flex gap-6 pointer-events-auto">
        <%# Event info card %>
        <div class="glass-card rounded-xl p-6 w-96">
          <div class="flex items-center gap-2 mb-4">
            <span class="material-symbols-outlined text-primary text-xl">event_upcoming</span>
            <h3 class="font-headline font-bold uppercase text-sm tracking-widest">
              <%= routeEvent.title %>
            </h3>
          </div>
          <p class="text-[10px] text-on-surface/60 uppercase tracking-widest mb-4">
            <%= routeEvent.location %>
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-[10px] text-on-surface/40 uppercase tracking-widest mb-1">Arrival ETA</p>
              <p class="text-sm font-headline font-bold"><%= routeEvent.arrivalEta %></p>
            </div>
            <div>
              <p class="text-[10px] text-on-surface/40 uppercase tracking-widest mb-1">Distance</p>
              <p class="text-sm font-headline font-bold"><%= routeEvent.distance %></p>
            </div>
          </div>
        </div>

        <%# Countdown card %>
        <div class="glass-card rounded-xl p-6" data-countdown
             data-hours="<%= countdown.hours %>"
             data-minutes="<%= countdown.minutes %>"
             data-seconds="<%= countdown.seconds %>">
          <p class="text-[10px] text-primary font-bold uppercase tracking-[0.3em] mb-2">
            <%= countdown.label %>
          </p>
          <div class="flex gap-4 items-baseline">
            <div class="flex flex-col items-center">
              <span class="text-3xl font-headline font-black tracking-tighter" data-countdown-hours>
                <%= String(countdown.hours).padStart(2, '0') %>
              </span>
              <span class="text-[8px] text-on-surface/60 uppercase tracking-widest">HRS</span>
            </div>
            <span class="text-xl text-primary/40 font-black">:</span>
            <div class="flex flex-col items-center">
              <span class="text-3xl font-headline font-black tracking-tighter" data-countdown-minutes>
                <%= String(countdown.minutes).padStart(2, '0') %>
              </span>
              <span class="text-[8px] text-on-surface/60 uppercase tracking-widest">MIN</span>
            </div>
            <span class="text-xl text-primary/40 font-black">:</span>
            <div class="flex flex-col items-center">
              <span class="text-3xl font-headline font-black tracking-tighter" data-countdown-seconds>
                <%= String(countdown.seconds).padStart(2, '0') %>
              </span>
              <span class="text-[8px] text-on-surface/60 uppercase tracking-widest">SEC</span>
            </div>
          </div>
        </div>
      </div>

      <%# BOTTOM row %>
      <div class="flex justify-between items-end gap-6 pointer-events-auto">
        <%# Telemetry card %>
        <div class="glass-card p-8 rounded-xl w-[520px]">
          <div class="flex justify-between items-start mb-6">
            <div>
              <h3 class="font-headline font-bold uppercase text-sm tracking-widest">Active Navigation</h3>
              <p class="text-[10px] text-on-surface/60 uppercase tracking-widest mt-1">
                Unit <%= telemetry.unitId %>
              </p>
            </div>
            <div class="flex gap-0.5 items-end">
              <div class="w-1 h-2 rounded-full bg-primary opacity-40"></div>
              <div class="w-1 h-3 rounded-full bg-primary opacity-60"></div>
              <div class="w-1 h-4 rounded-full bg-primary"></div>
            </div>
          </div>

          <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden relative mb-8">
            <div class="absolute left-0 h-full primary-gradient-glow rounded-full" style="width: <%= telemetry.progress %>%;"></div>
            <div class="absolute top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-white shadow-[0_0_8px_white]" style="left: <%= telemetry.progress %>%;"></div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-white/5 hover:bg-primary/20 transition-colors flex items-center justify-center cursor-pointer">
                <span class="material-symbols-outlined text-lg">view_in_ar</span>
              </div>
              <div>
                <p class="text-[10px] text-on-surface/60 uppercase tracking-widest">View Mode</p>
                <p class="text-xs font-headline font-bold"><%= telemetry.viewMode %></p>
              </div>
            </div>

            <div class="h-10 w-px bg-white/10"></div>

            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-white/5 hover:bg-primary/20 transition-colors flex items-center justify-center cursor-pointer">
                <span class="material-symbols-outlined text-lg">cloud_sync</span>
              </div>
              <div>
                <p class="text-[10px] text-on-surface/60 uppercase tracking-widest">Sync Status</p>
                <p class="text-xs font-headline font-bold"><%= telemetry.syncStatus %></p>
              </div>
            </div>
          </div>
        </div>

        <%# Action buttons %>
        <div class="flex flex-col gap-4 items-end">
          <button class="w-14 h-14 rounded-full glass-card flex items-center justify-center hover:bg-white/10 transition-colors">
            <span class="material-symbols-outlined">layers</span>
          </button>
          <button class="w-14 h-14 rounded-full glass-card flex items-center justify-center hover:bg-white/10 transition-colors">
            <span class="material-symbols-outlined">gps_fixed</span>
          </button>
          <button class="px-10 py-5 primary-gradient-glow rounded-xl font-headline font-black uppercase tracking-widest text-sm text-on-primary-container flex items-center gap-3 hover:brightness-110 transition-all active:scale-95">
            Initiate Drive
            <span class="material-symbols-outlined">arrow_forward</span>
          </button>
        </div>
      </div>
    </div>
  </main>
</div>
