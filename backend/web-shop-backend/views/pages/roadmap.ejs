<div class="relative h-screen overflow-hidden -mt-[72px] pt-[72px]">

  <%# ── Main map area ── %>
  <main class="pl-64 relative overflow-hidden h-full">
    <%# Layer 1: dot grid background %>
    <div class="absolute inset-0 z-0 map-grid bg-surface pointer-events-none"></div>

    <%# Layer 2: interactive map %>
    <div class="absolute inset-0 z-10 presentation-map-layer">
        <div id="presentation-map" class="h-[80vh] w-full rounded-2xl overflow-hidden"></div>
    </div>

    <%# Floating UI overlays %>
      <div class="relative z-50 p-12 h-[80vh] flex flex-col justify-between pointer-events-none presentation-ui-layer">
      <%# TOP row %>
      <div class="flex gap-6 pointer-events-auto items-start">
        <%# Event info card %>
        <div class="glass-card rounded-2xl p-6 w-[420px] relative overflow-hidden">
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/60 to-transparent"></div>
          <div class="flex items-center justify-between gap-2 mb-5">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-primary text-xl">event_upcoming</span>
              <h3 class="font-headline font-bold uppercase text-sm tracking-widest">
                <%= routeEvent.title %>
              </h3>
            </div>
            <span class="text-[9px] uppercase tracking-[0.3em] text-on-surface/40">Live</span>
          </div>
          <p class="text-[10px] text-on-surface/60 uppercase tracking-widest mb-5">
            <%= routeEvent.location %>
          </p>

          <%# Start → Destination corridor %>
          <div class="flex items-stretch gap-3 mb-5">
            <div class="flex flex-col items-center pt-1">
              <span class="w-2.5 h-2.5 rounded-full bg-white/60 ring-2 ring-white/20"></span>
              <span class="flex-1 w-px bg-gradient-to-b from-white/30 via-primary/40 to-primary my-1"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-primary ring-2 ring-primary/30"></span>
            </div>
            <div class="flex-1 flex flex-col justify-between gap-3 min-w-0">
              <div>
                <p class="text-[9px] uppercase tracking-widest text-on-surface/40">From</p>
                <p class="text-xs font-headline font-bold uppercase tracking-wide text-on-surface truncate" data-route-start>Start</p>
              </div>
              <div>
                <p class="text-[9px] uppercase tracking-widest text-primary/70">Destination</p>
                <p class="text-xs font-headline font-bold uppercase tracking-wide text-on-surface truncate" data-route-destination>Destination</p>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-4 border-t border-white/5 pt-4">
            <div>
              <p class="text-[9px] text-on-surface/40 uppercase tracking-widest mb-1">Arrival</p>
              <p class="text-sm font-headline font-bold" data-arrival-eta data-arrival-eta-value="<%= routeEvent.arrivalEta %>"><%= routeEvent.arrivalEta || '—' %></p>
            </div>
            <div>
              <p class="text-[9px] text-on-surface/40 uppercase tracking-widest mb-1">Remaining</p>
              <p class="text-sm font-headline font-bold" data-remaining-distance><%= routeEvent.distance %></p>
            </div>
            <div>
              <p class="text-[9px] text-on-surface/40 uppercase tracking-widest mb-1">Speed</p>
              <p class="text-sm font-headline font-bold"><span data-speed-value>0</span><span class="text-[10px] text-on-surface/50 ml-1">km/h</span></p>
            </div>
          </div>

          <div class="mt-4 flex items-center gap-2">
            <span data-status-dot class="h-2 w-2 rounded-full bg-white/40"></span>
            <p class="text-[10px] text-on-surface/60 uppercase tracking-widest">
              Status: <span data-status-text>idle</span>
            </p>
          </div>
        </div>

        <%# Countdown card %>
         <!--
        <div class="glass-card rounded-xl p-6" data-countdown
             data-hours="<%= countdown.hours %>"
             data-minutes="<%= countdown.minutes %>"
             data-seconds="<%= countdown.seconds %>">
          <p class="text-[10px] text-primary font-bold uppercase tracking-[0.3em] mb-2">
            <%= countdown.label %>
          </p>
          <div class="flex gap-4 items-baseline">
            <div class="flex flex-col items-center">
              <span class="text-3xl font-headline font-black tracking-tighter" data-countdown-hours>
                <%= String(countdown.hours).padStart(2, '0') %>
              </span>
              <span class="text-[8px] text-on-surface/60 uppercase tracking-widest">HRS</span>
            </div>
            <span class="text-xl text-primary/40 font-black">:</span>
            <div class="flex flex-col items-center">
              <span class="text-3xl font-headline font-black tracking-tighter" data-countdown-minutes>
                <%= String(countdown.minutes).padStart(2, '0') %>
              </span>
              <span class="text-[8px] text-on-surface/60 uppercase tracking-widest">MIN</span>
            </div>
            <span class="text-xl text-primary/40 font-black">:</span>
            <div class="flex flex-col items-center">
              <span class="text-3xl font-headline font-black tracking-tighter" data-countdown-seconds>
                <%= String(countdown.seconds).padStart(2, '0') %>
              </span>
              <span class="text-[8px] text-on-surface/60 uppercase tracking-widest">SEC</span>
            </div>
          </div>
        </div>%>
        -->
      </div>

      <%# BOTTOM row %>
      <div class="flex justify-between items-end gap-6 pointer-events-auto">
        <%# Telemetry card %>
        <div class="glass-card p-8 rounded-2xl w-[560px] relative overflow-hidden">
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/60 to-transparent"></div>
          <div class="flex justify-between items-start mb-6">
            <div>
              <h3 class="font-headline font-bold uppercase text-sm tracking-widest">Active Navigation</h3>
              <p class="text-[10px] text-on-surface/60 uppercase tracking-widest mt-1">
                Unit <%= telemetry.unitId %>
              </p>
            </div>
            <div class="flex gap-0.5 items-end">
              <div class="w-1 h-2 rounded-full bg-primary opacity-40"></div>
              <div class="w-1 h-3 rounded-full bg-primary opacity-60"></div>
              <div class="w-1 h-4 rounded-full bg-primary"></div>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-6 mb-6">
            <div>
              <p class="text-[10px] text-on-surface/60 uppercase tracking-widest">Status</p>
              <p class="text-xs font-headline font-bold uppercase tracking-widest mt-1" data-telemetry-status>idle</p>
            </div>
            <div>
              <p class="text-[10px] text-on-surface/60 uppercase tracking-widest">Progress</p>
              <p class="text-xs font-headline font-bold mt-1"><span data-telemetry-progress-value>0</span>%</p>
            </div>
            <div class="text-right">
              <p class="text-[10px] text-on-surface/60 uppercase tracking-widest">Last Update</p>
              <p class="text-xs font-headline font-bold uppercase tracking-widest mt-1" data-telemetry-update>—</p>
            </div>
          </div>

          <%# Progress track %>
          <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden relative">
            <div
              class="absolute left-0 h-full primary-gradient-glow rounded-full transition-[width] duration-700"
              data-telemetry-progress-bar
              style="width: <%= telemetry.progress %>%;"
            ></div>
            <div
              class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-white shadow-[0_0_12px_rgba(0,218,248,0.9)] transition-[left] duration-700"
              data-telemetry-progress-dot
              style="left: <%= telemetry.progress %>%;"
            ></div>
          </div>
          <div class="flex justify-between text-[9px] uppercase tracking-widest text-on-surface/40 mt-2">
            <span data-route-start-mini>Start</span>
            <span data-route-destination-mini>Destination</span>
          </div>
        </div>

        <%# Action buttons %>
        <div class="flex flex-col gap-4 items-end">
          <button data-action-layer title="Toggle map style"
                  class="group w-14 h-14 rounded-full glass-card flex items-center justify-center hover:bg-white/10 transition-colors relative">
            <span class="material-symbols-outlined">layers</span>
            <span class="absolute -left-2 -translate-x-full top-1/2 -translate-y-1/2 text-[9px] uppercase tracking-widest text-on-surface/0 group-hover:text-on-surface/60 transition-colors whitespace-nowrap pr-2"
                  data-layer-label>Dark</span>
          </button>
          <button data-action-locate title="Recenter on route"
                  class="group w-14 h-14 rounded-full glass-card flex items-center justify-center hover:bg-white/10 transition-colors relative">
            <span class="material-symbols-outlined">gps_fixed</span>
            <span class="absolute -left-2 -translate-x-full top-1/2 -translate-y-1/2 text-[9px] uppercase tracking-widest text-on-surface/0 group-hover:text-on-surface/60 transition-colors whitespace-nowrap pr-2">Recenter</span>
          </button>
          <div class="flex gap-3">
            <button
              class="w-14 h-14 rounded-full glass-card flex items-center justify-center hover:bg-white/10 transition-colors disabled:opacity-60"
              data-action-stop
              title="Pause simulation"
            >
              <span class="material-symbols-outlined">pause</span>
            </button>
            <button
              class="px-10 py-5 primary-gradient-glow rounded-xl font-headline font-black uppercase tracking-widest text-sm text-on-primary-container flex items-center gap-3 hover:brightness-110 transition-all active:scale-95 disabled:opacity-60"
              data-action-start
            >
              Initiate Drive
              <span class="material-symbols-outlined">arrow_forward</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
