<main class="pt-8 pb-20 px-8 max-w-page mx-auto">
  <div class="mb-12">
    <p class="font-label text-primary text-xs tracking-[0.3em] uppercase font-bold mb-3">Checkout</p>
    <h1 class="font-headline text-5xl font-black tracking-tighter text-white">YOUR CART</h1>
  </div>

  <% if (!cart || cart.items.length === 0) { %>
    <div class="glass-panel rounded-xl p-16 text-center">
      <span class="material-symbols-outlined text-on-surface/30 text-5xl mb-4">shopping_bag</span>
      <p class="font-body text-on-surface/60 mb-8">Your cart is empty.</p>
      <a href="/merchandise" class="btn-primary primary-glow inline-flex items-center gap-2">
        Browse Merchandise
        <span class="material-symbols-outlined text-lg">arrow_forward</span>
      </a>
    </div>
  <% } else { %>
    <div class="grid grid-cols-12 gap-12">
      <%# Items list %>
      <div class="col-span-8 space-y-4">
        <% cart.items.forEach(function(item) { %>
          <% const local = productMap[item.productId]; %>
          <div class="glass-panel rounded-xl p-6 flex items-center gap-6">
            <div class="w-24 h-24 bg-surface-container-high rounded-lg overflow-hidden relative shrink-0">
              <% if (local && local.image) { %>
                <img src="<%= local.image %>" alt="<%= item.name %>" class="absolute inset-0 w-full h-full object-cover" />
              <% } %>
            </div>

            <div class="flex-1 min-w-0">
              <h3 class="font-headline font-bold text-white text-lg"><%= item.name %></h3>
              <p class="text-on-surface/60 text-xs uppercase tracking-widest mt-1">
                $<%= item.price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> each
              </p>
            </div>

            <%# Quantity controls %>
            <div class="flex items-center gap-2">
              <form method="POST" action="/cart/items/<%= item.id %>/update">
                <input type="hidden" name="quantity" value="<%= Math.max(1, item.quantity - 1) %>" />
                <button type="submit" class="w-8 h-8 rounded border border-white/10 text-white hover:bg-white/5 transition-colors flex items-center justify-center" <%= item.quantity <= 1 ? 'disabled' : '' %>>
                  <span class="material-symbols-outlined text-sm">remove</span>
                </button>
              </form>
              <span class="w-8 text-center text-white font-bold"><%= item.quantity %></span>
              <form method="POST" action="/cart/items/<%= item.id %>/update">
                <input type="hidden" name="quantity" value="<%= item.quantity + 1 %>" />
                <button type="submit" class="w-8 h-8 rounded border border-white/10 text-white hover:bg-white/5 transition-colors flex items-center justify-center">
                  <span class="material-symbols-outlined text-sm">add</span>
                </button>
              </form>
            </div>

            <div class="text-right shrink-0 w-28">
              <p class="text-white font-headline font-bold">
                $<%= item.lineTotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
              </p>
            </div>

            <form method="POST" action="/cart/items/<%= item.id %>/remove">
              <button type="submit" class="text-on-surface/40 hover:text-error transition-colors" aria-label="Remove">
                <span class="material-symbols-outlined">close</span>
              </button>
            </form>
          </div>
        <% }); %>

        <div class="flex justify-end pt-4">
          <form method="POST" action="/cart/clear">
            <button type="submit" class="text-xs uppercase tracking-widest text-on-surface/40 hover:text-error transition-colors font-bold">
              Clear Cart
            </button>
          </form>
        </div>
      </div>

      <%# Summary %>
      <div class="col-span-4">
        <div class="glass-card rounded-xl p-8 border border-white/10 sticky top-24">
          <h3 class="font-headline font-bold text-white text-lg mb-6">Order Summary</h3>

          <div class="space-y-3 mb-6">
            <div class="flex justify-between text-sm">
              <span class="text-on-surface/60">Subtotal</span>
              <span class="text-white">
                $<%= cart.summary.subtotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
              </span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-on-surface/60">Shipping</span>
              <span class="text-white">$<%= shipping.toFixed(2) %></span>
            </div>
            <div class="h-px bg-white/10"></div>
            <div class="flex justify-between text-lg font-bold">
              <span class="text-white">Total</span>
              <span class="text-primary font-headline">
                $<%= total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
              </span>
            </div>
          </div>

          <form method="POST" action="/cart/checkout">
            <button type="submit" class="w-full py-4 bg-primary text-on-primary-container font-headline font-black uppercase tracking-widest rounded-lg hover:shadow-[0_0_25px_rgba(0,218,248,0.4)] transition-shadow">
              Checkout Now
            </button>
          </form>
          <p class="text-center text-[10px] text-on-surface/60 mt-3 tracking-widest uppercase">
            Secure Cloud-Native Payment
          </p>
        </div>
      </div>
    </div>
  <% } %>
</main>
