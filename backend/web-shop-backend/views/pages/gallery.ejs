<main class="pt-8 pb-12 px-8 max-w-page mx-auto">
  <%# ── Hero ── %>
  <% const heroParts = heroItem.title.split(' ');
     const heroFirst = heroParts.slice(0, Math.ceil(heroParts.length / 2)).join(' ');
     const heroSecond = heroParts.slice(Math.ceil(heroParts.length / 2)).join(' '); %>
  <div class="relative w-full h-[480px] mb-8 rounded-xl overflow-hidden group">
    <img
      src="<%= heroItem.image %>"
      alt="<%= heroItem.title %>"
      class="absolute inset-0 w-full h-full object-cover grayscale brightness-75 group-hover:scale-105 transition-transform duration-1000"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-surface-dim via-transparent to-transparent z-10"></div>
    <div class="absolute bottom-8 left-12 z-20">
      <p class="font-headline text-primary font-bold tracking-[0.2em] uppercase text-xs mb-2">
        Now Premiering
      </p>
      <h1 class="font-headline text-6xl font-black tracking-tighter text-white leading-none mb-4">
        <%= heroFirst %><br/>
        <span class="text-primary text-glow"><%= heroSecond %></span>
      </h1>
      <div class="flex gap-4">
        <button class="flex items-center gap-2 bg-gradient-to-r from-primary to-primary-container px-6 py-2.5 rounded-md font-headline font-semibold text-on-primary-container text-sm transition-opacity hover:opacity-90">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1">play_arrow</span>
          Watch Film
        </button>
        <button class="glass-panel flex items-center gap-2 border border-white/10 px-6 py-2.5 rounded-md font-headline font-semibold text-white text-sm transition-colors hover:border-white/25">
          Technical Specs
        </button>
      </div>
    </div>
  </div>

  <%# ── Media Grid ── %>
  <% const largeItem = gridItems.find(function(i){ return i.span === 'large'; });
     const mediumItem = gridItems.find(function(i){ return i.span === 'medium' && i.type === 'image'; });
     const videoItem = gridItems.find(function(i){ return i.type === 'video'; });
     const smallItem = gridItems.find(function(i){ return i.span === 'small'; }); %>
  <div class="grid grid-cols-12 gap-6 h-[460px]">
    <% if (largeItem) { %>
      <div class="col-span-6 group relative overflow-hidden rounded-xl bg-surface-container-low">
        <img src="<%= largeItem.image %>" alt="<%= largeItem.title %>" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 group-hover:grayscale-0 grayscale transition-all duration-700" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10"></div>
        <div class="absolute bottom-0 left-0 right-0 z-20 p-6">
          <p class="font-headline text-lg font-bold text-white"><%= largeItem.title %></p>
          <% if (largeItem.subtitle) { %>
            <p class="font-label text-sm text-on-surface/60"><%= largeItem.subtitle %></p>
          <% } %>
        </div>
      </div>
    <% } %>

    <% if (mediumItem) { %>
      <div class="col-span-3 group relative overflow-hidden rounded-xl bg-surface-container-low">
        <img src="<%= mediumItem.image %>" alt="<%= mediumItem.title %>" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent z-10"></div>
        <div class="absolute bottom-0 left-0 right-0 z-20 p-4 glass-panel border-t border-white/10 backdrop-blur-sm">
          <p class="font-headline text-sm font-semibold text-white"><%= mediumItem.title %></p>
          <% if (mediumItem.subtitle) { %>
            <p class="font-label text-xs text-on-surface/50"><%= mediumItem.subtitle %></p>
          <% } %>
        </div>
      </div>
    <% } %>

    <div class="col-span-3 grid grid-rows-2 gap-6">
      <% if (videoItem) { %>
        <div class="relative group overflow-hidden rounded-xl bg-surface-container-low h-full">
          <img src="<%= videoItem.image %>" alt="<%= videoItem.title %>" class="absolute inset-0 w-full h-full object-cover blur-[1px] opacity-40 group-hover:opacity-60 transition-all duration-700" />
          <div class="absolute inset-0 z-10 flex items-center justify-center">
            <div class="w-12 h-12 rounded-full bg-primary/20 backdrop-blur-md border border-primary/30 flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
              <span class="material-symbols-outlined text-primary text-xl">play_arrow</span>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 z-10 p-4">
            <p class="font-headline text-sm font-semibold text-white"><%= videoItem.title %></p>
            <p class="font-label text-xs text-on-surface/50">
              Video &bull; <%= videoItem.duration %>
            </p>
          </div>
        </div>
      <% } %>

      <% if (smallItem) { %>
        <div class="group relative overflow-hidden rounded-xl bg-surface-container-low">
          <img src="<%= smallItem.image %>" alt="<%= smallItem.title %>" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 group-hover:grayscale-0 grayscale transition-all duration-700" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent z-10"></div>
          <div class="absolute bottom-0 left-0 right-0 z-20 p-4">
            <p class="font-headline text-sm font-semibold text-white"><%= smallItem.title %></p>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <%# ── Fleet Evolution Banner ── %>
  <div class="mt-8 group relative overflow-hidden rounded-xl bg-surface-container-low h-48">
    <img src="<%= fleetItem.image %>" alt="<%= fleetItem.title %>" class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:scale-105 transition-transform duration-[2000ms]" />
    <div class="absolute inset-0 bg-gradient-to-r from-surface-dim via-surface-dim/80 to-transparent z-10"></div>
    <div class="absolute inset-y-0 left-0 z-20 flex flex-col justify-center px-12">
      <h2 class="font-headline text-3xl font-bold text-white mb-2">The Fleet Evolution</h2>
      <p class="font-body text-sm text-on-surface/60 max-w-md mb-4">
        From concept sketches to production-ready hypercar. Trace the lineage of every Aether model.
      </p>
      <a href="#" class="inline-flex items-center gap-2 font-headline text-sm font-semibold text-primary hover:text-primary/80 transition-colors">
        Explore All Models
        <span class="material-symbols-outlined text-lg">arrow_forward</span>
      </a>
    </div>
  </div>

  <%# ── CTA Section ── %>
  <div class="mt-8 py-8 text-center border-t border-white/5">
    <div class="w-12 h-0.5 bg-primary mx-auto mb-6"></div>
    <h2 class="font-headline text-4xl font-black tracking-tighter text-white mb-3">
      OWN THE HORIZON.
    </h2>
    <p class="font-body text-on-surface/50 text-sm max-w-lg mx-auto mb-8">
      Cloud-native engineering meets uncompromising design. Configure your Aether and join the next era of driving.
    </p>
    <div class="flex items-center justify-center gap-4">
      <a href="/configurator" class="px-8 py-3 rounded-md bg-white text-surface-dim font-headline font-semibold text-sm hover:bg-primary transition-colors">
        Build Yours
      </a>
      <a href="#" class="px-8 py-3 rounded-md border border-white/15 text-white font-headline font-semibold text-sm hover:border-white/30 transition-colors">
        Request Catalog
      </a>
    </div>
  </div>
</main>
