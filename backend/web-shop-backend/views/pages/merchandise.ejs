<main class="pt-8 pb-20 px-8 max-w-page mx-auto">
  <%# ── Hero + Category Tabs ── %>
  <div class="grid grid-cols-12 gap-12 mb-20 items-end">
    <div class="col-span-7">
      <h1 class="font-headline text-6xl font-black uppercase tracking-tight text-white">
        Engineered<br/>
        <span class="text-primary">Apparel</span>
      </h1>
      <p class="text-on-surface/60 font-body mt-4 max-w-lg">
        Performance-driven merchandise designed with the same precision engineering philosophy behind every Aether vehicle.
      </p>
    </div>
    <div class="col-span-5 flex justify-end">
      <div class="flex gap-4">
        <% categories.forEach(function(cat) { %>
          <% const isActive = cat === activeCategory; %>
          <a href="/merchandise?category=<%= encodeURIComponent(cat) %>"
             class="px-6 py-3 font-headline font-bold uppercase tracking-widest text-xs transition-all <%= isActive ? 'border-b-2 border-primary text-primary hover:bg-primary/5' : 'text-on-surface/60 hover:text-white' %>">
            <%= cat %>
          </a>
        <% }); %>
      </div>
    </div>
  </div>

  <%# ── Product Grid ── %>
  <div class="grid grid-cols-4 grid-rows-2 gap-8 mb-24">
    <% if (featuredProduct) { %>
      <div class="col-span-2 row-span-2 group relative overflow-hidden rounded-xl bg-surface-container-low transition-all duration-500 hover:shadow-[0_20px_50px_rgba(0,218,248,0.1)]">
        <img src="<%= featuredProduct.image %>" alt="<%= featuredProduct.name %>" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-8 w-full">
          <div class="flex justify-between items-end">
            <div>
              <span class="text-primary text-xs tracking-widest uppercase"><%= featuredProduct.category %></span>
              <h2 class="font-headline text-3xl font-bold text-white"><%= featuredProduct.name %></h2>
              <p class="text-on-surface/60 text-sm font-body mt-1"><%= featuredProduct.description %></p>
              <span class="font-headline font-bold text-white text-2xl mt-2 block">
                $<%= featuredProduct.price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
              </span>
            </div>
            <form method="POST" action="/cart/add" class="shrink-0">
              <input type="hidden" name="productId" value="<%= featuredProduct.id %>" />
              <input type="hidden" name="returnTo" value="/merchandise?category=<%= encodeURIComponent(activeCategory) %>" />
              <button type="submit" class="bg-primary w-14 h-14 rounded-full flex items-center justify-center hover:scale-110 transition-transform">
                <span class="material-symbols-outlined text-on-primary-container">add_shopping_cart</span>
              </button>
            </form>
          </div>
        </div>
      </div>
    <% } %>

    <% regularProducts.forEach(function(product) { %>
      <div class="group bg-surface-container-low rounded-xl overflow-hidden border-b-2 border-transparent hover:border-primary transition-all duration-300">
        <div class="aspect-square relative overflow-hidden bg-surface-container-high">
          <img src="<%= product.image %>" alt="<%= product.name %>" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
          <% if (product.badge) { %>
            <span class="absolute top-4 right-4 bg-surface-dim/80 backdrop-blur px-3 py-1 rounded-full text-[10px] font-bold tracking-tighter text-primary">
              <%= product.badge %>
            </span>
          <% } %>
        </div>
        <div class="p-6">
          <h3 class="font-headline font-bold text-lg text-white mb-1"><%= product.name %></h3>
          <p class="text-on-surface/60 text-sm font-body mb-4"><%= product.description %></p>
          <div class="flex justify-between items-center">
            <span class="font-headline font-bold text-white">
              $<%= product.price.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
            </span>
            <form method="POST" action="/cart/add">
              <input type="hidden" name="productId" value="<%= product.id %>" />
              <input type="hidden" name="returnTo" value="/merchandise?category=<%= encodeURIComponent(activeCategory) %>" />
              <button type="submit" class="text-primary hover:underline font-label text-xs font-bold uppercase tracking-widest">
                Add to Cart
              </button>
            </form>
          </div>
        </div>
      </div>
    <% }); %>
  </div>

  <%# ── Bottom: Owner Perks + Mini Cart ── %>
  <div class="grid grid-cols-12 gap-12">
    <div class="col-span-8">
      <div class="tonal-shift h-64 rounded-xl relative overflow-hidden flex items-center">
        <div class="relative z-10 p-10">
          <p class="text-primary text-xs tracking-widest uppercase font-bold mb-2">Exclusive</p>
          <h2 class="font-headline text-3xl font-black text-white uppercase tracking-tight">Owner Perks</h2>
          <p class="text-on-surface/60 font-body mt-2 max-w-md">
            Zenith owners receive 20% off all merchandise. Link your vehicle to unlock exclusive pricing and limited-edition drops.
          </p>
          <button class="mt-4 px-6 py-3 border border-primary text-primary font-headline font-bold uppercase tracking-widest text-xs rounded-lg hover:bg-primary/10 transition-colors">
            Link Vehicle
          </button>
        </div>
      </div>
    </div>

    <div class="col-span-4">
      <div class="glass-card rounded-xl p-8 border border-white/10">
        <div class="flex items-center gap-3 mb-6">
          <span class="material-symbols-outlined text-primary">shopping_bag</span>
          <h3 class="font-headline font-bold text-white text-lg">Your Cart</h3>
        </div>

        <% if (!cart || cart.items.length === 0) { %>
          <p class="text-on-surface/60 text-sm font-body">Your cart is empty.</p>
        <% } else { %>
          <div class="space-y-4 mb-6">
            <% cart.items.slice(0, 3).forEach(function(item) { %>
              <% const local = productMap[item.productId]; %>
              <div class="flex gap-3">
                <div class="w-12 h-12 bg-surface-container-high rounded overflow-hidden relative shrink-0">
                  <% if (local && local.image) { %>
                    <img src="<%= local.image %>" alt="<%= item.name %>" class="absolute inset-0 w-full h-full object-cover" />
                  <% } %>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-bold text-white truncate"><%= item.name %></p>
                  <p class="text-white text-xs">
                    $<%= item.lineTotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                  </p>
                </div>
              </div>
            <% }); %>
            <% if (cart.items.length > 3) { %>
              <p class="text-on-surface/60 text-xs">+<%= cart.items.length - 3 %> more items</p>
            <% } %>
          </div>

          <div class="border-t border-white/5 pt-4 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-on-surface/60">Subtotal</span>
              <span class="text-white">
                $<%= cart.summary.subtotal.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
              </span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-on-surface/60">Shipping</span>
              <span class="text-white">$<%= shipping.toFixed(2) %></span>
            </div>
            <div class="flex justify-between text-lg font-bold mt-2">
              <span class="text-white">Total</span>
              <span class="text-primary font-headline">
                $<%= total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
              </span>
            </div>
          </div>

          <a href="/cart" class="block text-center w-full py-4 bg-primary text-on-primary-container font-headline font-black uppercase tracking-widest rounded-lg hover:shadow-[0_0_25px_rgba(0,218,248,0.4)] transition-shadow mt-6">
            View Cart
          </a>
        <% } %>

        <p class="text-center text-[10px] text-on-surface/60 mt-3 tracking-widest uppercase">
          Secure Cloud-Native Payment
        </p>
      </div>
    </div>
  </div>
</main>
