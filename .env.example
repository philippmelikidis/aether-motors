# Aether Motors – environment template
#
# Copy this file to `.env` (same directory as docker-compose.yml) and fill in
# the values. Docker Compose loads `.env` automatically and substitutes the
# variables referenced in docker-compose.yml. The real `.env` is gitignored.
#
#   cp .env.example .env

# Google Gemini API key used by the AI Service (ai-service).
# Without it, POST /ai/configure responds with HTTP 503.
GEMINI_API_KEY=
